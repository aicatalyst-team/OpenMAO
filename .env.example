# OpenMAO requires no external credentials for the default demo.

# Optional local overrides:
# OPENMAO_DB=.openmao/openmao.sqlite3

# Optional: enable the real GitHub issue-comment provider (off by default;
# the default demo and tests need none of these).
# OPENMAO_GITHUB_ENABLED=1
# OPENMAO_CRED_GITHUB=<github-token>   # resolved for the cred_github handle
